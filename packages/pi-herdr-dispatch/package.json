{
  "name": "pi-herdr-dispatch",
  "version": "0.0.0-development",
  "private": true,
  "description": "Safely launch or dispatch work from Pi to agents on a local Herdr server",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "herdr",
    "coding-agent",
    "orchestration"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@types/node": "24.10.1",
    "tsx": "4.20.6",
    "typebox": "1.1.38",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
